{
  "productName": "inR Remapper",
  "version": "0.1.0",
  "identifier": "com.inr.remapper",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "inR Remapper",
        "width": 650,
        "height": 500,
        "resizable": false,
        "center": true,
        "decorations": true,
        "minWidth": 650,
        "minHeight": 500,
        "maxWidth": 650,
        "maxHeight": 500
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
